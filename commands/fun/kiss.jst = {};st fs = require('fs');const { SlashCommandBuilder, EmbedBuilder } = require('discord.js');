const { SlashCommandBuilder, EmbedBuilder } = require('discord.js');
const fs = require('fs');

let kissCount = {};
let globalKisses = 0;

if (fs.existsSync('./kisses.json')) {
  try {
    kissCount = JSON.parse(
      fs.readFileSync('./kisses.json', 'utf8')
    ) || {};
  } catch {
    kissCount = {};
  }
}

if (fs.existsSync('./globalKisses.json')) {
  try {
    const data = JSON.parse(
      fs.readFileSync('./globalKisses.json', 'utf8')
    );

    globalKisses = data.total || 0;

  } catch {
    globalKisses = 0;
  }
}

function save() {

  fs.writeFileSync(
    './kisses.json',
    JSON.stringify(kissCount, null, 2)
  );

  fs.writeFileSync(
    './globalKisses.json',
    JSON.stringify({ total: globalKisses }, null, 2)
  );
}

